{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Exile Farm Ledger",
  "version": "0.1.0",
  "identifier": "com.exilefarmledger.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Exile Farm Ledger",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM2NDVCRDc1RDNEOTNBOEEKUldTS090blRkYjFGeHJ0OHY4bjNJa0hyTzZIclBYVlRRT0FMaGJIOHl4b2NXQ3JGZ2phcnRWUVYK",
      "endpoints": [
        "https://github.com/FlipJaxx/PoE2-Farm-Ledger/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
